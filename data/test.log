/*C4*/SET SCHEMA PUBLIC
create sequence Booking_SEQ start with 1 increment by 50
create sequence Trip_SEQ start with 1 increment by 50
create sequence User_SEQ start with 1 increment by 50
create sequence Vehicle_SEQ start with 1 increment by 50
create table Booking (driverRating integer not null, passengerRating integer not null, seatBooked integer not null, totalPrice float(53) not null, bookedAt timestamp(6), id bigint not null, passenger_id bigint, trip_id bigint, bookingStatus varchar(255) check (bookingStatus in ('PENDING','CONFIRMED','COMPLETED','CANCELLED')), cancellationReason varchar(255), driverComment varchar(255), passengerComment varchar(255), primary key (id))
create table Trip (availableSeats integer not null, petsAllowed boolean not null, pricePerSeat float(53) not null, smokingAllowed boolean not null, totalSeats integer not null, departureTime timestamp(6), driver_id bigint, estimatedArrivalTime timestamp(6), id bigint not null, arrivalAddress varchar(255), arrivalCity varchar(255), departureAddress varchar(255), departureCity varchar(255), description varchar(255), tripStatus varchar(255) check (tripStatus in ('PLANNED','IN_PROGRESS','COMPLETED','CANCELLED')), primary key (id))
create table Trip_User (passengers_id bigint not null, trips_id bigint not null)
create table User (birthDate date, isActive boolean not null, licenseExpiry date, ratingAverage float(53), ratingByDrivers float(53), totalTripsBooked integer, totalTripsOffered integer, id bigint not null, vehicle_id bigint unique, DTYPE varchar(31) not null, email varchar(255), firstName varchar(255), lastName varchar(255), licenceNumber varchar(255), password varchar(255), paymentMethod varchar(255) check (paymentMethod in ('CASH','MOBILE_MONEY','CARD')), phone varchar(255), primary key (id))
create table Vehicle (hasAirConditioning boolean not null, maxSeats integer not null, year integer not null, id bigint not null, color varchar(255), fuelType varchar(255) check (fuelType in ('ESSENCE','DIESEL','ELECTRIQUE')), licensePlate varchar(255), marque varchar(255), model varchar(255), primary key (id))
alter table Booking add constraint FK4om2hgauost0od9y0hcl5xw86 foreign key (passenger_id) references User
alter table Booking add constraint FKmju2e4jtwm39r38f7653b9kab foreign key (trip_id) references Trip
alter table Trip add constraint FKfb7jp51m81xjqjjs8brs9xehj foreign key (driver_id) references User
alter table Trip_User add constraint FKcalv1576vacptphjn38t6rf28 foreign key (passengers_id) references User
alter table Trip_User add constraint FK8dscmetfb02299j1nkwl81o1f foreign key (trips_id) references Trip
alter table User add constraint FK6u01387vbq76w5c112xvr9ej1 foreign key (vehicle_id) references Vehicle
