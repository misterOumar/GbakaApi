CREATE SCHEMA PUBLIC AUTHORIZATION DBA
CREATE SEQUENCE PUBLIC.BOOKING_SEQ AS INTEGER START WITH 1 INCREMENT BY 50
CREATE SEQUENCE PUBLIC.TRIP_SEQ AS INTEGER START WITH 1 INCREMENT BY 50
CREATE SEQUENCE PUBLIC.USER_SEQ AS INTEGER START WITH 1 INCREMENT BY 50
CREATE SEQUENCE PUBLIC.VEHICLE_SEQ AS INTEGER START WITH 1 INCREMENT BY 50
CREATE MEMORY TABLE PUBLIC.BOOKING(DRIVERRATING INTEGER NOT NULL,PASSENGERRATING INTEGER NOT NULL,SEATBOOKED INTEGER NOT NULL,TOTALPRICE DOUBLE NOT NULL,BOOKEDAT TIMESTAMP,ID BIGINT NOT NULL PRIMARY KEY,PASSENGER_ID BIGINT,TRIP_ID BIGINT,BOOKINGSTATUS VARCHAR(255),CANCELLATIONREASON VARCHAR(255),DRIVERCOMMENT VARCHAR(255),PASSENGERCOMMENT VARCHAR(255),CHECK((PUBLIC.BOOKING.BOOKINGSTATUS) IN (('PENDING'),('CONFIRMED'),('COMPLETED'),('CANCELLED'))))
CREATE MEMORY TABLE PUBLIC.TRIP(AVAILABLESEATS INTEGER NOT NULL,PETSALLOWED BOOLEAN NOT NULL,PRICEPERSEAT DOUBLE NOT NULL,SMOKINGALLOWED BOOLEAN NOT NULL,TOTALSEATS INTEGER NOT NULL,DEPARTURETIME TIMESTAMP,DRIVER_ID BIGINT,ESTIMATEDARRIVALTIME TIMESTAMP,ID BIGINT NOT NULL PRIMARY KEY,ARRIVALADDRESS VARCHAR(255),ARRIVALCITY VARCHAR(255),DEPARTUREADDRESS VARCHAR(255),DEPARTURECITY VARCHAR(255),DESCRIPTION VARCHAR(255),TRIPSTATUS VARCHAR(255),CHECK((PUBLIC.TRIP.TRIPSTATUS) IN (('PLANNED'),('IN_PROGRESS'),('COMPLETED'),('CANCELLED'))))
CREATE MEMORY TABLE PUBLIC.TRIP_USER(PASSENGERS_ID BIGINT NOT NULL,TRIPS_ID BIGINT NOT NULL,CONSTRAINT FK8DSCMETFB02299J1NKWL81O1F FOREIGN KEY(TRIPS_ID) REFERENCES PUBLIC.TRIP(ID))
CREATE MEMORY TABLE PUBLIC.USER(BIRTHDATE DATE,ISACTIVE BOOLEAN NOT NULL,LICENSEEXPIRY DATE,RATINGAVERAGE DOUBLE,RATINGBYDRIVERS DOUBLE,TOTALTRIPSBOOKED INTEGER,TOTALTRIPSOFFERED INTEGER,ID BIGINT NOT NULL PRIMARY KEY,VEHICLE_ID BIGINT,DTYPE VARCHAR(31) NOT NULL,EMAIL VARCHAR(255),FIRSTNAME VARCHAR(255),LASTNAME VARCHAR(255),LICENCENUMBER VARCHAR(255),PASSWORD VARCHAR(255),PAYMENTMETHOD VARCHAR(255),PHONE VARCHAR(255),UNIQUE(VEHICLE_ID),CHECK((PUBLIC.USER.PAYMENTMETHOD) IN (('CASH'),('MOBILE_MONEY'),('CARD'))))
CREATE MEMORY TABLE PUBLIC.VEHICLE(HASAIRCONDITIONING BOOLEAN NOT NULL,MAXSEATS INTEGER NOT NULL,YEAR INTEGER NOT NULL,ID BIGINT NOT NULL PRIMARY KEY,COLOR VARCHAR(255),FUELTYPE VARCHAR(255),LICENSEPLATE VARCHAR(255),MARQUE VARCHAR(255),MODEL VARCHAR(255),CHECK((PUBLIC.VEHICLE.FUELTYPE) IN (('ESSENCE'),('DIESEL'),('ELECTRIQUE'))))
ALTER TABLE PUBLIC.BOOKING ADD CONSTRAINT FK4OM2HGAUOST0OD9Y0HCL5XW86 FOREIGN KEY(PASSENGER_ID) REFERENCES PUBLIC.USER(ID)
